{
  "name": "@dudousxd/nestjs-codegen-arktype",
  "version": "0.1.0",
  "description": "ArkType validation adapter for @dudousxd/nestjs-codegen — renders the schema IR to arktype source.",
  "license": "MIT",
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-codegen": "workspace:^"
  },
  "devDependencies": {
    "@dudousxd/nestjs-codegen": "workspace:*",
    "@types/node": "^20.0.0",
    "ts-morph": "^28.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
