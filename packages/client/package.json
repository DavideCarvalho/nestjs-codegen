{
  "name": "@dudousxd/nestjs-client",
  "version": "0.6.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/nestjs-codegen.git",
    "directory": "packages/client"
  },
  "description": "Framework-neutral runtime for nestjs-codegen output: typed fetcher with optional superjson transformer. No Inertia dependency.",
  "license": "MIT",
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./superjson": {
      "import": {
        "types": "./dist/superjson/index.d.ts",
        "default": "./dist/superjson/index.js"
      },
      "require": {
        "types": "./dist/superjson/index.d.cts",
        "default": "./dist/superjson/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "CHANGELOG.md", "skills"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "rxjs": "^7.0.0",
    "superjson": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    },
    "superjson": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "11.1.6",
    "@types/node": "20.19.42",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "superjson": "2.2.2",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["tanstack-intent"]
}
