{
  "name": "@dudousxd/nestjs-client",
  "version": "0.2.0",
  "description": "Framework-neutral runtime for nestjs-codegen output: typed fetcher with optional superjson transformer. No Inertia dependency.",
  "license": "MIT",
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "20.19.42",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
