{
  "name": "@dudousxd/nestjs-codegen",
  "version": "0.2.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/nestjs-codegen.git",
    "directory": "packages/core"
  },
  "description": "Extensible codegen core for NestJS: class-validator/contract discovery → neutral schema IR → pluggable validation adapters.",
  "license": "MIT",
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nestjs-codegen": "./bin/nestjs-codegen.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nest": {
      "types": "./dist/nest/index.d.ts",
      "import": "./dist/nest/index.js",
      "require": "./dist/nest/index.cjs"
    },
    "./extension": {
      "types": "./dist/extension/index.d.ts",
      "import": "./dist/extension/index.js",
      "require": "./dist/extension/index.cjs"
    }
  },
  "files": ["dist", "bin", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "cac": "6.7.14",
    "chokidar": "3.6.0",
    "fast-glob": "3.3.3",
    "ts-morph": "28.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9.0.0",
    "tsx": ">=4.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "tsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dudousxd/nestjs-codegen-zod": "workspace:*",
    "@nestjs/common": "11.1.26",
    "@nestjs/core": "11.1.26",
    "@tanstack/react-query": "5.101.0",
    "@types/node": "20.19.42",
    "class-validator": "0.14.4",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "4.1.8",
    "zod": "3.25.76"
  },
  "engines": {
    "node": ">=20"
  }
}
