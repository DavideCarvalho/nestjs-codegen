/** Awaitable request handle. \`await api.x.y({...})\` runs the fetch; extensions add query/mutation helpers. */
type __Req<R> = {
  then<T1 = R, T2 = never>(
    onfulfilled?: ((value: R) => T1 | PromiseLike<T1>) | null,
    onrejected?: ((reason: unknown) => T2 | PromiseLike<T2>) | null,
