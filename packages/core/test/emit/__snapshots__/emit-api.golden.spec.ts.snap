  const __promise = () => {
    __p ??= run();
    return __p;
  };
  return {
    then: (onfulfilled, onrejected) => __promise().then(onfulfilled, onrejected),
    catch: (onrejected) => __promise().catch(onrejected),
    finally: (onfinally) => __promise().finally(onfinally),
    fetch: run,
