{
  "name": "@dudousxd/nestjs-codegen-tanstack",
  "version": "0.4.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/nestjs-codegen.git",
    "directory": "packages/tanstack"
  },
  "description": "TanStack Query client layer for @dudousxd/nestjs-codegen — emits queryOptions/mutationOptions handles in the generated api.ts.",
  "license": "MIT",
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-codegen": ">=0.3.0 <1"
  },
  "devDependencies": {
    "@dudousxd/nestjs-codegen": "workspace:*",
    "@types/node": "20.19.42",
    "ts-morph": "28.0.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
