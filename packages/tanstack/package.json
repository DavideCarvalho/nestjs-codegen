{
  "name": "@dudousxd/nestjs-codegen-tanstack",
  "version": "0.2.0",
  "description": "TanStack Query client layer for @dudousxd/nestjs-codegen — emits queryOptions/mutationOptions handles in the generated api.ts.",
  "license": "MIT",
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-codegen": "workspace:^"
  },
  "devDependencies": {
    "@dudousxd/nestjs-codegen": "workspace:*",
    "@types/node": "20.19.42",
    "ts-morph": "28.0.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
