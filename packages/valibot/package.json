{
  "name": "@dudousxd/nestjs-codegen-valibot",
  "version": "0.4.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/nestjs-codegen.git",
    "directory": "packages/valibot"
  },
  "description": "Valibot validation adapter for @dudousxd/nestjs-codegen — renders the schema IR to valibot source.",
  "license": "MIT",
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-codegen": ">=0.3.0 <1"
  },
  "devDependencies": {
    "@dudousxd/nestjs-codegen": "workspace:*",
    "@types/node": "20.19.42",
    "ts-morph": "28.0.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
